{
  "manifest_version": 3,
  "name": "Nexus",
  "version": "1.0.1",
  "author": "IntelSecLab",
  "description": "Passive web security reconnaissance platform. Detects exposed API keys, tokens, configs, and tech stack for pentesters.",
  "homepage_url": "https://github.com/intelseclab/nexus",
  "permissions": [
    "activeTab",
    "scripting",
    "webRequest",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scanner/patterns.js", "scanner/finding.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
